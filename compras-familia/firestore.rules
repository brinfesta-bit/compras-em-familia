rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Apenas usuários autenticados podem acessar os dados
    match /feira_atual/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /feiras_salvas/{feiraid} {
      allow read, write: if request.auth != null;
      match /itens/{itemid} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
